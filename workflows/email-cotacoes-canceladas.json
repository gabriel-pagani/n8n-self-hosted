      "parameters": {
        "jsCode": "let rows = items.map(i => {\n  return `<tr>\n            <td>${i.json.CODCOLIGADA}</td>\n            <td>${i.json.CODCOTACAO}</td>\n            <td>${i.json.IDFLUIG}</td>\n          </tr>`;\n}).join(\"\");\n\nreturn [{\n  json: {\n    html: `\n    <h4>Cotações canceladas no RM com status \"Aberta\" no Fluig</h4>\n    <table border=\"1\" cellpadding=\"5\">\n      <tr>\n        <th>Coligada</th>\n        <th>Cotação</th>\n        <th>Id Fluig</th>\n      </tr>\n      ${rows}\n    </table>\n    `\n  }\n}];"
