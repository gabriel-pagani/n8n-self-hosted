{
  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH COTACOES AS (\n\t/* Cotações com o status \"Cancelada\" no RM */\n\tSELECT \n\t\tTCCOTACAO.CODCOLIGADA,\n\t\tTCCOTACAO.CODCOTACAO,\n\t\tZMDWFLUIGCOTACAO.IDFLUIG\n\n\tFROM CORPORE.DBO.TCCOTACAO\n\t\tJOIN CORPORE.DBO.ZMDWFLUIGCOTACAO ON (\n\t\t\tZMDWFLUIGCOTACAO.CODCOLIGADA = TCCOTACAO.CODCOLIGADA AND\n\t\t\tZMDWFLUIGCOTACAO.CODCOTACAO = TCCOTACAO.CODCOTACAO\n\t\t)\n\n\tWHERE 1=1\n\t\tAND TCCOTACAO.STSCOTACAO = 7\n\t\tAND ZMDWFLUIGCOTACAO.IDFLUIG IN (\n\t\t\t/* Solicitações com o status \"Aberta\" no fluig */\n\t\t\tSELECT \n\t\t\t\tNUM_PROCES AS ID_FLUIG\n\t\n\t\t\tFROM FLUIG.DBO.PROCES_WORKFLOW \n\n\t\t\tWHERE 1=1\n\t\t\t\tAND COD_DEF_PROCES = 'Aprovação de Cotação'\n\t\t\t\tAND STATUS = 0\n\t\t)\n)\n\nSELECT CODCOLIGADA, CODCOTACAO, IDFLUIG, 'Pendente' AS STATUS FROM COTACOES\n\nUNION ALL\n\nSELECT NULL, NULL, NULL, 'Ok' WHERE NOT EXISTS (SELECT 1 FROM COTACOES)\n\nORDER BY CODCOLIGADA, CODCOTACAO\n",
        "options": {}
      },
