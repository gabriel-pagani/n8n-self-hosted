    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH COTACOES AS (\n\tSELECT \n\t\tZMDWFLUIGCOTACAO.CODCOLIGADA,\n\t\tZMDWFLUIGCOTACAO.CODCOTACAO,\n\t\tZMDWFLUIGCOTACAO.IDFLUIG,\n        DESCATIVIDADE\n\t\n\tFROM CORPORE.DBO.ZMDWFLUIGCOTACAO\n\t\tJOIN CORPORE.DBO.TCCOTACAO ON (\n\t\t\tTCCOTACAO.CODCOLIGADA = ZMDWFLUIGCOTACAO.CODCOLIGADA AND\n\t\t\tTCCOTACAO.CODCOTACAO = ZMDWFLUIGCOTACAO.CODCOTACAO\n\t\t)\n\n\tWHERE 1=1\n\t\tAND DESCATIVIDADE IN ('Em Processamento TBC', 'Suporte a Integração')\n\t\tAND STSCOTACAO <> 7\n\t\tAND ZMDWFLUIGCOTACAO.IDFLUIG IN (\n\t\t\t/* Solicitações com o status \"Aberta\" no fluig */\n\t\t\tSELECT \n\t\t\t\tNUM_PROCES AS ID_FLUIG\n\t\n\t\t\tFROM FLUIG.DBO.PROCES_WORKFLOW \n\n\t\t\tWHERE 1=1\n\t\t\t\tAND COD_DEF_PROCES = 'Aprovação de Cotação'\n\t\t\t\tAND STATUS = 0\n\t\t)\n)\n\nSELECT \n\tCODCOLIGADA, \n\tCODCOTACAO, \n\tIDFLUIG, \n    DESCATIVIDADE,\n\t'Pendente' AS STATUS \n\nFROM COTACOES\n\nUNION ALL\n\nSELECT \n\tNULL, \n\tNULL, \n\tNULL, \n    NULL,\n\t'Ok' \n\nWHERE NOT EXISTS (SELECT 1 FROM COTACOES)\n\nORDER BY \n    CODCOLIGADA, \n    CODCOTACAO\n",
        "options": {}
      },
